# Telegram Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram user id of the single owner allowed to manage routes
OWNER_ID=123456789

# SQLite database file path
DATABASE_URL=sqlite:///bot.db

# Logging
LOG_LEVEL=INFO

# Optional: MTProto listener (Telethon) for realtime delete-sync
# Get TELETHON_API_ID / TELETHON_API_HASH from https://my.telegram.org -> API development tools
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=telethon_session
# Optional comma-separated filter for source chats to watch for deletions
# TELETHON_WATCH_CHAT_IDS=-1001234567890,-1009876543210

# Optional: default timezone for scheduler
# TIMEZONE=UTC
